# LexGuard AI — Backend Environment Template
# Copy this to .env and fill in your real values

# 1. AI Engine
GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"
GEMINI_MODEL="gemini-2.0-flash"
# Optional Groq fallback used when Gemini hits quota/timeout
# GROQ_API_KEY="YOUR_GROQ_API_KEY"
# GROQ_MODEL="llama-3.3-70b-versatile"

# 2. Database
MONGO_URL="mongodb://localhost:27017"
DB_NAME="lexguard_db"

# 3. Security
# Secret token for admin routes
ADMIN_TOKEN="YOUR_ADMIN_SECRET_TOKEN"

# 4. Networking
CORS_ORIGINS="http://localhost:3000,https://your-production-domain.com"
# Optional regex for preview deployments. Leave unset to enforce the allow-list strictly.
# CORS_ORIGIN_REGEX="https://([a-z0-9-]+\\.)*vercel\\.app$"
