# ============================================================
# Caddyfile — Optional Reverse Proxy + Auto HTTPS for LexGuard EC2
# ============================================================
# To use this:
#   1. Own a domain (e.g., api.lexguard.ai)
#   2. Point an A record to your Elastic IP
#   3. Uncomment the caddy service in docker-compose.yml
#   4. Place this Caddyfile next to docker-compose.yml
#   5. docker compose up -d caddy
#
# Caddy automatically provisions Let's Encrypt certificates.
# No manual cert management needed.
# ============================================================

api.yourdomain.com {
    reverse_proxy backend:8000

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Compress responses
    encode gzip

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}
