{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/frontend/public/admin.html"
    },
    {
      "source": "/(css|js|assets)/(.*)",
      "destination": "/frontend/public/$1/$2"
    },
    {
      "source": "/favicon.png",
      "destination": "/frontend/public/favicon.png"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
